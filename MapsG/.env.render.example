APP_NAME=GeoCampo Backend
APP_ENV=production
APP_DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/defaultdb?sslmode=require

STORAGE_BACKEND=r2
STORAGE_PATH=/tmp/geocampo/storage
ORIGINAL_FILES_PATH=/tmp/geocampo/storage/originals
PROCESSED_FILES_PATH=/tmp/geocampo/storage/processed
PACKAGES_PATH=/tmp/geocampo/storage/packages
TEMP_PATH=/tmp/geocampo/temp
OBSERVATION_PHOTOS_PATH=/tmp/geocampo/storage/photos

R2_BUCKET=geocampo-storage
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_REGION=auto
R2_PUBLIC_BASE_URL=

JWT_SECRET_KEY=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
EMAIL_VERIFICATION_CODE_EXPIRE_MINUTES=10
PASSWORD_RESET_CODE_EXPIRE_MINUTES=10

APP_FRONTEND_URL=https://YOUR_FRONTEND_DOMAIN
CORS_ORIGINS=https://YOUR_FRONTEND_DOMAIN

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=GeoCampo
SMTP_USE_TLS=true

MAX_UPLOAD_SIZE_MB=500
CELERY_TASK_ALWAYS_EAGER=true
BOOTSTRAP_ADMIN_EMAIL=admin@geocampo.local
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME
BOOTSTRAP_ADMIN_NAME=GeoCampo Admin
